# Django
DJANGO_SECRET_KEY=replace-with-a-strong-secret-key
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=.railway.app,your-backend-service.up.railway.app

# Frontend origin(s)
DJANGO_CORS_ALLOWED_ORIGINS=https://react-todo.utsavbhattarai.info.np
DJANGO_CSRF_TRUSTED_ORIGINS=https://react-todo.utsavbhattarai.info.np

# Railway PostgreSQL (Railway usually injects this automatically)
# DATABASE_URL=postgresql://user:password@host:port/dbname

# Optional
DJANGO_SECURE_SSL_REDIRECT=true
